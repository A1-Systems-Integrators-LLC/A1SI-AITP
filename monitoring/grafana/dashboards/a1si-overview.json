{
  "dashboard": {
    "id": null,
    "uid": "a1si-overview",
    "title": "A1SI-AITP Overview",
    "tags": ["a1si", "trading"],
    "timezone": "utc",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Job Queue",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {"expr": "job_queue_pending", "legendFormat": "Pending"},
          {"expr": "job_queue_running", "legendFormat": "Running"}
        ]
      },
      {
        "id": 2,
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {"expr": "circuit_breaker_state", "legendFormat": "{{exchange}}"}
        ]
      },
      {
        "id": 3,
        "title": "Scheduler Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {"expr": "scheduler_running", "legendFormat": "Running"},
          {"expr": "scheduler_job_count", "legendFormat": "Jobs"}
        ]
      },
      {
        "id": 4,
        "title": "Orders Created",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {"expr": "rate(orders_created_total[5m])", "legendFormat": "Orders/min"}
        ]
      },
      {
        "id": 5,
        "title": "ML Models",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {"expr": "ml_models_total", "legendFormat": "Total Models"}
        ]
      },
      {
        "id": 6,
        "title": "Signal Cache",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 4},
        "targets": [
          {"expr": "signal_cache_size", "legendFormat": "Cache Size"}
        ]
      },
      {
        "id": 7,
        "title": "Strategy Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 4},
        "targets": [
          {"expr": "orchestrator_strategies_paused", "legendFormat": "Paused"}
        ]
      }
    ],
    "schemaVersion": 38
  }
}
