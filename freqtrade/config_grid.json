{
    "trading_mode": "spot",
    "max_open_trades": 5,
    "stake_currency": "USDT",
    "stake_amount": 40,
    "tradable_balance_ratio": 0.95,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 200,
    "cancel_open_orders_on_exit": false,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "kraken",
        "key": "",
        "secret": "",
        "ccxt_config": {
            "defaultType": "swap"
        },
        "ccxt_sync_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [],
        "pair_blacklist": [
            ".*DOWN/.*",
            ".*UP/.*",
            ".*BEAR/.*",
            ".*BULL/.*",
            "USDC/USDT",
            "USDG/USDT",
            "DAI/USDT",
            "TUSD/USDT",
            "PYUSD/USDT",
            "XAUT/USDT"
        ]
    },
    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 8,
            "sort_key": "quoteVolume",
            "min_value": 0,
            "refresh_period": 1800
        },
        {
            "method": "AgeFilter",
            "min_days_listed": 30
        },
        {
            "method": "SpreadFilter",
            "max_spread_ratio": 0.005
        }
    ],
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 4086,
        "verbosity": "error",
        "enable_openapi": true,
        "jwt_secret_key": "change_me_grid",
        "CORS_origins": ["http://localhost:4001"],
        "username": "SET_VIA_ENV_FREQTRADE__API_SERVER__USERNAME",
        "password": "SET_VIA_ENV_FREQTRADE__API_SERVER__PASSWORD"
    },
    "db_url": "sqlite:///tradesv3.grid.dryrun.sqlite",
    "bot_name": "a1si-grid-dca",
    "initial_state": "running",
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "stoploss": "limit",
        "stoploss_on_exchange": true
    },
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "user_data_dir": "./freqtrade/user_data"
}
